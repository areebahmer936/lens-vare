# Normalize line endings to LF on commit
* text=auto eol=lf

# Python
*.py text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Config / data
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite binary
